{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Lua: Syntax Check",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/tools/lua_syntax_check.sh"
      ],
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}/tools/lua_syntax_check.ps1"
        ]
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [
        {
          "owner": "lua",
          "fileLocation": [
            "absolute"
          ],
          "pattern": {
            "regexp": "^(.*):(\\d+):\\s*(.*)$",
            "file": 1,
            "line": 2,
            "message": 3
          }
        }
      ]
    }
  ]
}
